# =============================================================
# SISTEMA DE SALAS PUCRS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA commite o arquivo .env
# =============================================================

# --- FRONTEND (prefixo VITE_ obrigatório para exposição ao browser) ---

# URL do projeto Supabase (visível no dashboard: Settings > API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Chave anon/public do Supabase (safe para expor no frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL base da API — use http://localhost:3000 para dev local com vercel dev
VITE_API_URL=http://localhost:3000

# --- BACKEND (serverless Vercel — nunca exposto ao browser) ---

# URL do projeto Supabase (igual ao VITE_SUPABASE_URL)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Chave service_role do Supabase — SEGREDO, nunca expor ao frontend
# Visível em: Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL da API Python para extração de PDF (hospedada no Render.com)
# Opcional — necessário apenas para o módulo de upload de grade
PYTHON_API_URL=https://seu-servico-de-extracao.onrender.com
